/*
!/.cursorignore
!/.cursorrules

# Allow the project folder for traversal but ignore all contents
!/TriangleGame/
/TriangleGame/*

# Surgical exceptions for work files only
!/TriangleGame/TriangleGame.csproj
!/TriangleGame/MainPage.xaml
!/TriangleGame/MainPage.xaml.cs

# Playground: visible to Cursor (separate from MAUI)
!/Sandbox/
!/Sandbox/**

# VS Code / Cursor tasks (open playground, etc.)
!/.vscode/
!/.vscode/**

# Change logs
!/CHANGELOG/
!/CHANGELOG/**

# Allow commit/push helper script
!/Commit-AndPush.ps1
